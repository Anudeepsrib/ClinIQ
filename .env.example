# ClinIQ local demo configuration.
# Copy this file to .env and fill only the values you need.

ENVIRONMENT=development
DEBUG=false

# Browser/API access
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true

# Authentication
# Generate a local value with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-local-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480
ALLOW_DEMO_ADMIN=false
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=

# Optional AI providers. Leave blank for startup/build/test-only local runs.
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=azure_openai
LLM_MODEL=gpt-4o
LOCAL_LLM_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000

# Embeddings and retrieval
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=multimodal-embedding-002
EMBEDDING_DIMENSIONS=3072
AZURE_SEARCH_ENABLED=false
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_PREFIX=cliniq-dept

# Local runtime paths
CHROMA_PERSIST_DIRECTORY=./data/vector_db
DOCS_DIRECTORY=./data/docs
USERS_DB_PATH=./data/users.db
VAULT_DB_PATH=./data/vault.db

# Upload limits
MAX_UPLOAD_BYTES=26214400
UPLOAD_QUARANTINE_DIR=./tmp/uploads

# Department list
HOSPITAL_DEPARTMENTS=radiology,pharmacy,administration,nursing,laboratory,emergency,cardiology,oncology,orthopedics,pediatrics,general

# External tracing is disabled by default to prevent PHI egress.
ENABLE_EXTERNAL_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ClinIQ-Hospital-Beta

# Chat history persistence is disabled by default for safe local demos.
CHAT_HISTORY_ENABLED=false
AZURE_CHROMA_HOST=localhost
AZURE_CHROMA_PORT=8000
AZURE_CHROMA_AUTH_TOKEN=

MAX_QUERY_RETRIES=3
